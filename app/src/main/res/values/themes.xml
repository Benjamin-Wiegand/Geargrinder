<resources>
    <style name="Base.Theme.Geargrinder" parent="Theme.Material3.DayNight">
        <item name="colorDockBackground">@color/black</item>
        <item name="colorDockForeground">@color/white</item>
        <item name="colorDockItemInactive">#666666</item>
        <item name="colorDockItemActive">?attr/colorPrimary</item>

        <item name="colorAppModal">?attr/colorSurfaceContainer</item>

        <item name="dynamicColorThemeOverlay">@style/ThemeOverlay.Geargrinder.DynamicColors</item>
        <item name="actionBarStyle">@style/ThemeOverlay.Geargrinder.ActionBar</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.Geargrinder.AlertDialog</item>
        <item name="tabStyle">@style/Widget.Material3.TabLayout</item>
    </style>

    <style name="Base.ThemeOverlay.Geargrinder.DynamicColors" parent="@style/ThemeOverlay.Material3.DynamicColors.DayNight">
        <item name="colorDockForeground">@color/material_dynamic_neutral_variant99</item>
        <item name="colorDockBackground">@color/material_dynamic_neutral_variant10</item>
        <item name="colorDockItemInactive">@color/material_dynamic_neutral40</item>
        <item name="colorDockItemActive">@color/material_dynamic_primary70</item>

        <item name="colorAppModal">@color/material_dynamic_neutral_variant70</item>

    </style>

    <style name="ThemeOverlay.Geargrinder.ActionBar" parent="Widget.Material3.ActionBar.Solid">
        <item name="background">?android:attr/windowBackground</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="ThemeOverlay.Geargrinder.AlertDialog" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="colorBackgroundFloating">@macro/m3_comp_dialog_container_color</item>
    </style>

    <style name="Theme.Geargrinder" parent="Base.Theme.Geargrinder" />
    <style name="ThemeOverlay.Geargrinder.DynamicColors" parent="Base.ThemeOverlay.Geargrinder.DynamicColors" />


    <style name="Theme.Geargrinder.Projection" parent="Theme.Geargrinder">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Geargrinder.Invisible" parent="Theme.Geargrinder">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">#00000000</item>
    </style>
</resources>