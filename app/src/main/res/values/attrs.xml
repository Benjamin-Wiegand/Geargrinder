<?xml version="1.0" encoding="utf-8"?>
<resources>
    
    <declare-styleable name="FileImportPreference">
        <attr name="maxFileSize" format="integer" />
        <attr name="acceptedMimeTypes" format="string" />   <!-- comma separated -->
    </declare-styleable>

    <declare-styleable name="Theme">
        <attr name="colorDockForeground" format="color" />
        <attr name="colorDockBackground" format="color" />

        <attr name="colorAppModal" format="color" />

        <attr name="colorDockItemInactive" format="color" />
        <attr name="colorDockItemActive" format="color" />
    </declare-styleable>
    
</resources>